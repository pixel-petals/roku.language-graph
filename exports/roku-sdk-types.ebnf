  | "ifSGNodeHttpAgentAccess"
  | "ifSGScreen"
  | "ifScreen"
  | "ifSetMessagePort"
  | "ifSocket"
  | "ifSocketAddress"
  | "ifSocketAsync"
  | "ifSocketCastOption"
  | "ifSocketConnection"
  | "ifSocketConnectionOption"
  | "ifSocketConnectionStatus"
  | "ifSocketOption"
  | "ifSocketStatus"
  | "ifSourceIdentity"
  | "ifSprite"
