node_modules/
grammars/brightscript/node_modules/
grammars/brightscript/build/
*.node
exports/.graphify-state/

# raw/ephemeral captures (bsbench, etc.) — the durable output lives in
# checked-in files like src/parse/roku-benchmark/roku-benchmark.catalog.json
.artifacts/

# code-review-graph generated files
.code-review-graph/

# Ignore submodule *contents*, not the submodule directories themselves —
# VSCode's git scanner walks a freshly-cloned submodule's working tree as
# plain untracked files before it recognizes the .git boundary, which can
# freeze the UI on a large submodule. A bare `modules/` ignores the
# top-level path too, which blocks `git submodule add` without -f.
modules/*/**
