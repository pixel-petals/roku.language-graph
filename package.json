{
  "name": "roku-graphify",
  "version": "0.1.0",
  "description": "BrightScript code graph analysis tool powered by brighterscript",
  "bin": {
    "roku-graphify": "src/cli/cli.analyze-file.mjs"
  },
  "scripts": {
    "build-grammar": "cd packages/graphify && npx tree-sitter generate && npx node-gyp configure && npx node-gyp build",
    "test": "node --check src/cli/cli.analyze-file.mjs && node --check src/cli/cli.analyze-app.mjs && node --check src/cli/cli.generate-sdk-exports.mjs && node --check src/cli/cli.run-benchmark.mjs && node --check src/cli/cli.inspect-db.mjs && node --test",
    "analyze-app": "node src/cli/cli.analyze-app.mjs",
    "analyze-file": "node src/cli/cli.analyze-file.mjs",
    "generate-sdk-exports": "node src/cli/cli.generate-sdk-exports.mjs",
    "generate-ebnf": "node src/grammar/ebnf/ebnf.generate.mjs",
    "run-benchmark": "node src/cli/cli.run-benchmark.mjs",
    "inspect-db": "node src/cli/cli.inspect-db.mjs",
    "inspect-db:app": "node src/cli/cli.inspect-db.mjs examples/roku-app/graphify-output/.graphify-state/graph.pgdata",
    "inspect-db:scenegraph": "node src/cli/cli.inspect-db.mjs exports/scenegraph/.graphify-state/graph.pgdata",
    "inspect-db:brightscript": "node src/cli/cli.inspect-db.mjs exports/brightscript/.graphify-state/graph.pgdata"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@sentropic/graphify": "^0.15.0",
    "brighterscript": "1.0.0-alpha.52",
    "brighterscript-jsdocs-plugin": "^0.8.0",
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.7"
  },
  "keywords": [
    "roku",
    "brightscript",
    "brighterscript",
    "graph",
    "code-analysis"
  ],
  "license": "MIT"
}
